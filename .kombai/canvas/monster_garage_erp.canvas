      "html": "<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --color-carbon: #1B1B1B;\n        --color-gold: #FFD800;\n        --color-smoke: #F5F5F5;\n        --color-dark-bg: #121212;\n    }\n\n    body {\n        margin: 0;\n        font-family: 'IBM_Plex_Sans', sans-serif;\n        background-color: var(--color-dark-bg);\n        color: white;\n    }\n\n    .sidebar-active {\n        background: rgba(255, 255, 255, 0.05);\n        border-left: 4px solid var(--color-gold);\n        color: var(--color-gold);\n    }\n\n    .chart-bar-hover:hover {\n        background-color: rgba(27, 27, 27, 0.4);\n    }\n</style>\n\n<div class=\"flex h-[1000px] bg-[var(--color-dark-bg)]\" data-kid=\"1\">\n    \n    <aside class=\"w-64 bg-[var(--color-carbon)] border-r border-white/5 flex flex-col shrink-0\" data-kid=\"1-0\">\n        <div class=\"p-8\" data-kid=\"1-0-0\">\n            <div class=\"flex items-center gap-3\" data-kid=\"1-0-0-0\">\n                <div class=\"w-10 h-10 bg-[var(--color-gold)] rounded-md flex items-center justify-center\" data-kid=\"1-0-0-0-0\">\n                    <i class=\"ti ti-tool text-[var(--color-carbon)] text-2xl\" data-kid=\"1-0-0-0-0-0\"></i>\n                </div>\n                <div data-kid=\"1-0-0-0-1\">\n                    <h1 class=\"font-['Plus_Jakarta_Sans'] font-extrabold text-white text-lg leading-tight uppercase tracking-tighter\" data-kid=\"1-0-0-0-1-0\">Monster<br data-kid=\"1-0-0-0-1-0-0\"><span class=\"text-[var(--color-gold)]\" data-kid=\"1-0-0-0-1-0-1\">Garage</span></h1>\n                </div>\n            </div>\n        </div>\n        \n        <nav class=\"flex-1 px-4 space-y-2 mt-4\" data-kid=\"1-0-1\">\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white transition-colors rounded-lg group\" data-kid=\"1-0-1-0\">\n                <i class=\"ti ti-layout-dashboard text-xl group-hover:text-[var(--color-gold)]\" data-kid=\"1-0-1-0-0\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"1-0-1-0-1\">Tableau de bord</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white transition-colors rounded-lg group\" data-kid=\"1-0-1-1\">\n                <i class=\"ti ti-wrench text-xl group-hover:text-[var(--color-gold)]\" data-kid=\"1-0-1-1-0\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"1-0-1-1-1\">Atelier</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 sidebar-active rounded-r-lg\" data-kid=\"1-0-1-2\">\n                <i class=\"ti ti-chart-bar text-xl\" data-kid=\"1-0-1-2-0\"></i>\n                <span class=\"font-bold text-sm\" data-kid=\"1-0-1-2-1\">Statistiques</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white transition-colors rounded-lg group\" data-kid=\"1-0-1-3\">\n                <i class=\"ti ti-users text-xl group-hover:text-[var(--color-gold)]\" data-kid=\"1-0-1-3-0\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"1-0-1-3-1\">Clients</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/50 hover:text-white transition-colors rounded-lg group\" data-kid=\"1-0-1-4\">\n                <i class=\"ti ti-settings text-xl group-hover:text-[var(--color-gold)]\" data-kid=\"1-0-1-4-0\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"1-0-1-4-1\">Paramètres</span>\n            </a>\n        </nav>\n        \n        <div class=\"p-4 border-t border-white/5\" data-kid=\"1-0-2\">\n            <div class=\"bg-white/5 rounded-xl p-4\" data-kid=\"1-0-2-0\">\n                <div class=\"flex items-center gap-3 mb-4\" data-kid=\"1-0-2-0-0\">\n                    <img src=\"https://i.pravatar.cc/100?u=garage_admin\" class=\"w-10 h-10 rounded-full border-2 border-[var(--color-gold)]\" alt=\"Profile\" decoding=\"async\" loading=\"lazy\" data-kid=\"1-0-2-0-0-0\">\n                    <div class=\"overflow-hidden\" data-kid=\"1-0-2-0-0-1\">\n                        <p class=\"text-sm font-bold text-white truncate\" data-kid=\"1-0-2-0-0-1-0\">Marco Rossi</p>\n                        <p class=\"text-xs text-white/40 truncate font-medium\" data-kid=\"1-0-2-0-0-1-1\">Chef d'atelier</p>\n                    </div>\n                </div>\n                <button class=\"w-full flex items-center justify-center gap-2 py-2.5 text-xs font-bold text-[var(--color-gold)] border border-[var(--color-gold)]/20 rounded-lg hover:bg-[var(--color-gold)] hover:text-[var(--color-carbon)] transition-all\" data-kid=\"1-0-2-0-1\">\n                    <i class=\"ti ti-logout text-base\" data-kid=\"1-0-2-0-1-0\"></i>\n                    Déconnexion\n                </button>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col overflow-y-auto\" data-kid=\"1-1\">\n        \n        <header class=\"h-20 border-b border-white/5 px-10 flex items-center justify-between bg-[var(--color-carbon)]/50 backdrop-blur-md sticky top-0 z-10\" data-kid=\"1-1-0\">\n            <div data-kid=\"1-1-0-0\">\n                <h2 class=\"text-2xl font-['Plus_Jakarta_Sans'] font-extrabold text-white tracking-tight\" data-kid=\"1-1-0-0-0\">Statistiques & Performance</h2>\n                <div class=\"flex items-center gap-2 mt-0.5\" data-kid=\"1-1-0-0-1\">\n                    <span class=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"1-1-0-0-1-0\"></span>\n                    <p class=\"text-xs text-white/40 font-bold uppercase tracking-widest\" data-kid=\"1-1-0-0-1-1\">Live • Mise à jour il y a 2 min</p>\n                </div>\n            </div>\n            <div class=\"flex items-center gap-6\" data-kid=\"1-1-0-1\">\n                <div class=\"flex items-center gap-3 px-5 py-2.5 bg-white/5 rounded-xl border border-white/10 shadow-inner\" data-kid=\"1-1-0-1-0\">\n                    <i class=\"ti ti-calendar text-[var(--color-gold)] text-lg\" data-kid=\"1-1-0-1-0-0\"></i>\n                    <span class=\"text-sm text-white/90 font-bold tracking-tight\" data-kid=\"1-1-0-1-0-1\">Lundi, 24 Mai 2024</span>\n                </div>\n                <div class=\"flex items-center gap-2 border-l border-white/10 pl-6\" data-kid=\"1-1-0-1-1\">\n                    <button class=\"p-2.5 bg-white/5 rounded-lg text-white/60 hover:text-[var(--color-gold)] hover:bg-white/10 transition-all cursor-pointer\" data-kid=\"1-1-0-1-1-0\"><i class=\"ti ti-refresh text-xl\" data-kid=\"1-1-0-1-1-0-0\"></i></button>\n                    <button class=\"p-2.5 bg-white/5 rounded-lg text-white/60 hover:text-[var(--color-gold)] hover:bg-white/10 transition-all cursor-pointer relative\" data-kid=\"1-1-0-1-1-1\">\n                        <i class=\"ti ti-bell text-xl\" data-kid=\"1-1-0-1-1-1-0\"></i>\n                        <span class=\"absolute top-2 right-2 w-2 h-2 bg-rose-500 rounded-full border-2 border-[var(--color-carbon)]\" data-kid=\"1-1-0-1-1-1-1\"></span>\n                    </button>\n                </div>\n            </div>\n        </header>\n\n        \n        <div class=\"p-10 space-y-10\" data-kid=\"1-1-1\">\n            \n            \n            <section class=\"grid grid-cols-4 gap-6\" data-kid=\"1-1-1-0\">\n                \n                <div class=\"bg-[var(--color-smoke)] p-6 rounded-2xl shadow-lg border border-black/5 group hover:translate-y-[-4px] transition-transform duration-300\" data-kid=\"1-1-1-0-0\">\n                    <div class=\"flex justify-between items-start mb-4\" data-kid=\"1-1-1-0-0-0\">\n                        <div data-kid=\"1-1-1-0-0-0-0\">\n                            <p class=\"text-[10px] font-bold text-black/40 uppercase tracking-[0.2em] mb-1\" data-kid=\"1-1-1-0-0-0-0-0\">Revenu du jour</p>\n                            <h3 class=\"text-3xl font-['Plus_Jakarta_Sans'] font-extrabold text-[var(--color-carbon)]\" data-kid=\"1-1-1-0-0-0-0-1\">12,850€</h3>\n                        </div>\n                        <div class=\"p-2 bg-emerald-500/10 text-emerald-600 rounded-lg flex items-center gap-1 text-[11px] font-bold border border-emerald-500/20\" data-kid=\"1-1-1-0-0-0-1\">\n                            <i class=\"ti ti-trending-up\" data-kid=\"1-1-1-0-0-0-1-0\"></i>\n                            +14%\n                        </div>\n                    </div>\n                    <div class=\"h-12 w-full mt-2\" data-kid=\"1-1-1-0-0-1\">\n                        <svg class=\"w-full h-full drop-shadow-sm\" viewBox=\"0 0 100 40\" preserveAspectRatio=\"none\" data-kid=\"1-1-1-0-0-1-0\">\n                            <path d=\"M0 35 Q 10 25, 20 30 T 40 15 T 60 25 T 80 5 T 100 10\" fill=\"none\" stroke=\"#10b981\" stroke-width=\"4\" stroke-linecap=\"round\" data-kid=\"1-1-1-0-0-1-0-0\"></path>\n                        </svg>\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-[var(--color-smoke)] p-6 rounded-2xl shadow-lg border border-black/5 group hover:translate-y-[-4px] transition-transform duration-300\" data-kid=\"1-1-1-0-1\">\n                    <div class=\"flex justify-between items-start mb-4\" data-kid=\"1-1-1-0-1-0\">\n                        <div data-kid=\"1-1-1-0-1-0-0\">\n                            <p class=\"text-[10px] font-bold text-black/40 uppercase tracking-[0.2em] mb-1\" data-kid=\"1-1-1-0-1-0-0-0\">Dossiers Actifs</p>\n                            <h3 class=\"text-3xl font-['Plus_Jakarta_Sans'] font-extrabold text-[var(--color-carbon)]\" data-kid=\"1-1-1-0-1-0-0-1\">42</h3>\n                        </div>\n                        <div class=