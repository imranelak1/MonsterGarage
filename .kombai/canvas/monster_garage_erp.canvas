      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;900&family=Inter:wght@400;500;600&display=swap');\n\n  :root {\n    --color-monster-jaune: #facc15;\n    --color-carbon-bg: #0f1115;\n    --color-carbon-surface: #1a1d23;\n    --color-steel-border: #2d3139;\n    --color-steel-text: #94a3b8;\n  }\n\n  body {\n    background-color: var(--color-carbon-bg);\n    color: white;\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n\n  .font-outfit {\n    font-family: 'Outfit', sans-serif;\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: var(--color-steel-border);\n    border-radius: 10px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: #3f4551;\n  }\n\n  .table-row-hover:hover .hover-accent {\n    transform: scaleY(1);\n  }\n\n  .table-row-hover:hover .code-highlight {\n    text-shadow: 0 0 15px rgba(251, 191, 36, 0.4);\n    letter-spacing: 0.05em;\n  }\n\n  .glass-card {\n    background: rgba(26, 29, 35, 0.8);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--color-steel-border);\n  }\n</style>\n\n<div class=\"min-h-[900px] w-full p-8 flex flex-col gap-8\" data-kid=\"1\">\n  \n  <header class=\"flex flex-col md:flex-row md:items-center justify-between gap-6\" data-kid=\"1-0\">\n    <div class=\"flex items-center gap-6\" data-kid=\"1-0-0\">\n      <div class=\"p-4 bg-white/10 rounded-2xl border border-white/20 shadow-[0_0_20px_rgba(255,255,255,0.05)]\" data-kid=\"1-0-0-0\">\n        <img src=\"/api/local/images/image.png\" alt=\"Monster Garage\" class=\"h-12 w-auto object-contain brightness-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"1-0-0-0-0\">\n      </div>\n      <div data-kid=\"1-0-0-1\">\n        <div class=\"flex items-center gap-3 mb-1\" data-kid=\"1-0-0-1-0\">\n        