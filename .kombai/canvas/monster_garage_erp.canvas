      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --monster-yellow: #FFD800;\n    --sidebar-bg: #0A0A0A;\n  }\n\n  body {\n    background-color: #FAFAFA;\n    font-family: 'IBM Plex Sans', sans-serif;\n    margin: 0;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-heading { font-family: 'Plus Jakarta Sans', sans-serif; }\n\n  .hero-container {\n    background: radial-gradient(circle at 20% 30%, #222222 0%, #000000 100%);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .noise-overlay {\n    position: absolute;\n    inset: 0;\n    z-index: 1;\n    opacity: 0.05;\n    pointer-events: none;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  }\n\n  .monster-btn-primary {\n    background-color: var(--monster-yellow);\n    box-shadow: 0 10px 40px -10px rgba(255, 216, 0, 0.5);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .monster-btn-primary:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 15px 50px -10px rgba(255, 216, 0, 0.7);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n  }\n\n  .bloom-gold {\n    filter: drop-shadow(0 0 15px rgba(255, 216, 0, 0.6));\n  }\n\n  .sidebar-link-active {\n    background: rgba(255, 216, 0, 0.1);\n    border: 1px solid rgba(255, 216, 0, 0.2);\n    color: var(--monster-yellow);\n  }\n\n  @keyframes spin-slow {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n  .animate-spin-slow {\n    animation: spin-slow 12s linear infinite;\n  }\n\n  .no-scrollbar::-webkit-scrollbar {\n    display: none;\n  }\n</style>\n\n<div class=\"flex w-full min-h-[1000px] overflow-hidden\" data-kid=\"1\">\n  \n  <aside class=\"w-72 bg-[var(--sidebar-bg)] text-white flex flex-col shrink-0 border-r border-white/5\" data-kid=\"1-0\">\n    <div class=\"p-8\" data-kid=\"1-0-0\">\n      <div class=\"bg-white/5 p-4 rounded-2xl border border-white/10 flex items-center justify-center h-20 group cursor-pointer overflow-hidden\" data-kid=\"1-0-0-0\">\n        <div class=\"font-heading font-black text-xl tracking-tighter transition-transform group-hover:scale-105\" data-kid=\"1-0-0-0-0\">\n          MONSTER<span class=\"text-[var(--monster-yellow)]\" data-kid=\"1-0-0-0-0-0\">GARAGE</span>\n        </div>\n      </div>\n    </div>\n\n    <nav class=\"mt-4 flex-1 px-5 space-y-8\" data-kid=\"1-0-1\">\n      <div data-kid=\"1-0-1-0\">\n        <p class=\"text-[10px] font-bold text-gray-600 uppercase tracking-[0.25em] px-4 mb-4\" data-kid=\"1-0-1-0-0\">Principal</p>\n        <div class=\"space-y-1.5\" data-kid=\"1-0-1-0-1\">\n          <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3.5 text-gray-400 hover:text-white transition-all rounded-xl group\" data-kid=\"1-0-1-0-1-0\">\n            <i class=\"ti ti-layout-dashboard text-xl opacity-60 group-hover:opacity-100\" data-kid=\"1-0-1-0-1-0-0\"></i>\n            <span class=\"text-sm font-semibold\" data-kid=\"1-0-1-0-1-0-1\">Tableau de Bord</span>\n          </a>\n          <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3.5 sidebar-link-active transition-all rounded-xl\" data-kid=\"1-0-1-0-1-1\">\n            <i class=\"ti ti-tool text-xl\" data-kid=\"1-0-1-0-1-1-0\"></i>\n            <span class=\"text-sm font-semibold\" data-kid=\"1-0-1-0-1-1-1\">Atelier & Opérations</span>\n          </a>\n          <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3.5 text-gray-400 hover:text-white transition-all rounded-xl group\" data-kid=\"1-0-1-0-1-2\">\n            <i class=\"ti ti-file-invoice text-xl opacity-60 group-hover:opacity-100\" data-kid=\"1-0-1-0-1-2-0\"></i>\n            <span class=\"text-sm font-semibold\" data-kid=\"1-0-1-0-1-2-1\">Facturation</span>\n          </a>\n        </div>\n      </div>\n\n      <div data-kid=\"1-0-1-1\">\n        <p class=\"text-[10px] font-bold text-gray-600 uppercase tracking-[0.25em] px-4 mb-4\" data-kid=\"1-0-1-1-0\">Gestion</p>\n        <div class=\"space-y-1.5\" data-kid=\"1-0-1-1-1\">\n          <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3.5 text-gray-400 hover:text-white transition-all rounded-xl group\" data-kid=\"1-0-1-1-1-0\">\n            <i class=\"ti ti-users text-xl opacity-60 group-hover:opacity-100\" data-kid=\"1-0-1-1-1-0-0\"></i>\n            <span class=\"text-sm font-semibold\" data-kid=\"1-0-1-1-1-0-1\">Clients & CRM</span>\n          </a>\n          <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3.5 text-gray-400 hover:text-white transition-all rounded-xl group\" data-kid=\"1-0-1-1-1-1\">\n            <i class=\"ti ti-package text-xl opacity-60 group-hover:opacity-100\" data-kid=\"1-0-1-1-1-1-0\"></i>\n            <span class=\"text-sm font-semibold\" data-kid=\"1-0-1-1-1-1-1\">Inventaire Pièces</span>\n          </a>\n        </div>\n      </div>\n    </nav>\n\n    <div class=\"p-6 border-t border-white/5\" data-kid=\"1-0-2\">\n      <div class=\"flex items-center gap-3 bg-white/5 p-4 rounded-2xl border border-white/10\" data-kid=\"1-0-2-0\">\n        <img src=\"https://i.pravatar.cc/100?u=admin_marc\" class=\"w-10 h-10 rounded-xl border border-white/10\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"1-0-2-0-0\">\n        <div class=\"flex-1 overflow-hidden\" data-kid=\"1-0-2-0-1\">\n          <p class=\"text-xs font-bold text-white truncate\" data-kid=\"1-0-2-0-1-0\">Marc G.</p>\n          <p class=\"text-[9px] text-gray-500 font-bold uppercase tracking-widest truncate\" data-kid=\"1-0-2-0-1-1\">Chef d'Atelier</p>\n        </div>\n        <button class=\"text-gray-500 hover:text-red-400 cursor-pointer p-1\" data-kid=\"1-0-2-0-2\">\n          <i class=\"ti ti-logout text-lg\" data-kid=\"1-0-2-0-2-0\"></i>\n        </button>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col bg-[#FAFAFA] overflow-y-auto no-scrollbar\" data-kid=\"1-1\">\n    \n    <header class=\"h-20 bg-white border-b border-gray-100 flex items-center justify-between px-10 shrink-0\" data-kid=\"1-1-0\">\n      <div class=\"flex items-center gap-10\" data-kid=\"1-1-0-0\">\n        <div class=\"flex items-center gap-2.5 px-4 py-2 bg-[var(--monster-yellow)]/10 rounded-full border border-[var(--monster-yellow)]/20\" data-kid=\"1-1-0-0-0\">\n          <div class=\"w-2 h-2 bg-[var(--monster-yellow)] rounded-full animate-pulse\" data-kid=\"1-1-0-0-0-0\"></div>\n          <span class=\"text-[10px] font-black text-black uppercase tracking-wider font-heading\" data-kid=\"1-1-0-0-0-1\">Live Workshop Control</span>\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"1-1-0-0-1\">\n          <p class=\"text-[9px] font-bold text-gray-400 uppercase tracking-widest leading-none mb-1\" data-kid=\"1-1-0-0-1-0\">Site Actuel</p>\n          <p class=\"text-sm font-bold text-black font-body\" data-kid=\"1-1-0-0-1-1\">Monster Garage — <span class=\"text-gray-500 font-medium\" data-kid=\"1-1-0-0-1-1-0\">Lyon Ouest</span></p>\n        </div>\n      </div>\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"1-1-0-1\">\n        <div class=\"text-right mr-4\" data-kid=\"1-1-0-1-0\">\n          <p class=\"text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-1\" data-kid=\"1-1-0-1-0-0\">Sync Automatique</p>\n          <p class=\"text-sm font-bold text-black\" data-kid=\"1-1-0-1-0-1\">24 MAI 2024 — <span class=\"text-gray-500 font-medium\" data-kid=\"1-1-0-1-0-1-0\">14:45</span></p>\n        </div>\n        <button class=\"w-10 h-10 bg-gray-50 border border-gray-200 rounded-full flex items-center justify-center text-gray-400 hover:text-black transition-all cursor-pointer\" data-kid=\"1-1-0-1-1\">\n          <i class=\"ti ti-search text-xl\" data-kid=\"1-1-0-1-1-0\"></i>\n        </button>\n        <div class=\"relative\" data-kid=\"1-1-0-1-2\">\n          <button class=\"w-10 h-10 bg-gray-50 border border-gray-200 rounded-full flex items-center justify-center text-gray-400 hover:text-black transition-all cursor-pointer\" data-kid=\"1-1-0-1-2-0\">\n            <i class=\"ti ti-bell text-xl\" data-kid=\"1-1-0-1-2-0-0\"></i>\n          </button>\n          <span class=\"absolute top-2.5 right-2.5 w-2 h-2 bg-[var(--monster-yellow)] border-2 border-white rounded-full\" data-kid=\"1-1-0-1-2-1\"></span>\n        </div>\n      </div>\n    </header>\n\n    <div class=\"p-10 space-y-12\" data-kid=\"1-1-1\">\n      \n      <section class=\"hero-container rounded-[56px] p-20 min-h-[620px] flex items-center shadow-2xl relative overflow-hidden\" data-kid=\"1-1-1-0\">\n        <div class=\"noise-overlay\" data-kid=\"1-1-1-0-0\"></div>\n        \n        \n        <div class=\"absolute right-[-100px] top-1/2 -translate-y-1/2 opacity-[0.08] text-white pointer-events-none select-none z-0\" data-kid=\"1-1-1-0-1\">\n          <i class=\"ti ti-wrench text-[820px] -rotate-12\" data-kid=\"1-1-1-0-1-0\"></i>\n        </div>\n\n        <div class=\"relative z-10 w-full flex items-center justify-between gap-16\" data-kid=\"1-1-1-0-2\">\n          <div class=\"flex-1 max-w-3xl\" data-kid=\"1-1-1-0-2-0\">\n            <div class=\"inline-flex items-center gap-2.5 bg-white/5 border border-white/10 px-4 py-2 rounded-full mb-10 backdrop-blur-sm\" data-kid=\"1-1-1-0-2-0-0\">\n              <i class=\"ti ti-layout-grid text-[var(--monster-yellow)] text-xs\" data-kid=\"1-1-1-0-2-0-0-0\"></i>\n              <span class=\"text-[9px] font-bold text-gray-300 uppercase tracking-[0.2em] font-heading\" data-kid=\"1-1-1-0-2-0-0-1\">Terminal d'entrée atelier</span>\n            </div>\n            \n            <h1 class=\"font-heading text-[82px] text-white font-black leading-[0.9] mb-8 tracking-tighter\" data-kid=\"1-1-1-0-2-0-1\">\n              Démarrer un<br data-kid=\"1-1-1-0-2-0-1-0\">\n              nouveau<br data-kid=\"1-1-1-0-2-0-1-1\">\n              <span class=\"text-[var(--monster-yellow)]\" data-kid=\"1-1-1-0-2-0-1-2\">dossier atelier</span>\n            </h1>\n            \n            <div class=\"space-y-1.5 mb-14\" data-kid=\"1-1-1-0-2-0-2\">\n              <p class=\"text-gray-400 text-2xl font-medium leading-snug max-w-xl\" data-kid=\"1-1-1-0-2-0-2-0\">Initialisez une nouvelle prise en charge véhicule en quelques secondes.</p>\n              <p class=\"text-gray-400 text-2xl font-medium leading-snug max-w-xl\" data-kid=\"1-1-1-0-2-0-2-1\">Scannez le VIN pour une récupération automatique des données.</p>\n            </div>\n\n            <div class=\"flex items-center gap-4\" data-kid=\"1-1-1-0-2-0-3\">\n              <button class=\"monster-btn-primary px-10 py-4.5 rounded-2xl font-heading font-black text-[11px] tracking-[0.15em] uppercase cursor-pointer text-black\" data-kid=\"1-1-1-0-2-0-3-0\">\n                Nouveau Dossier\n              </button>\n              <button class=\"bg-white/5 border border-white/10 text-white px-9 py-4.5 rounded-2xl font-heading font-black text-[11px] tracking-[0.15em] uppercase hover:bg-white/10 transition-all cursor-pointer\" data-kid=\"1-1-1-0-2-0-3-1\">\n                Scanner VIN\n              </button>\n              <button class=\"bg-white/5 border border-white/10 text-white px-9 py-4.5 rounded-2xl font-heading font-black text-[11px] tracking-[0.15em] uppercase hover:bg-white/10 transition-all cursor-pointer\" data-kid=\"1-1-1-0-2-0-3-2\">\n                Historique\n              </button>\n            </div>\n          </div>\n\n          \n          <div class=\"flex-shrink-0\" data-kid=\"1-1-1-0-2-1\">\n            <div class=\"glass-card rounded-[48px] p-10 w-[440px] flex flex-col gap-10 shadow-3xl\" data-kid=\"1-1-1-0-2-1-0\">\n              <div class=\"flex items-center gap-6\" data-kid=\"1-1-1-0-2-1-0-0\">\n                <div class=\"w-16 h-16 bg-[var(--monster-yellow)] rounded-2xl flex items-center justify-center bloom-gold\" data-kid=\"1-1-1-0-2-1-0-0-0\">\n                  <i class=\"ti ti-car-garage text-black text-3xl\" data-kid=\"1-1-1-0-2-1-0-0-0-0\"></i>\n                </div>\n                <div data-kid=\"1-1-1-0-2-1-0-0-1\">\n                  <p class=\"text-[9px] font-extrabold text-gray-500 uppercase tracking-widest mb-1.5\" data-kid=\"1-1-1-0-2-1-0-0-1-0\">Dernière Entrée</p>\n                  <h3 class=\"text-2xl font-heading font-black text-white tracking-tight\" data-kid=\"1-1-1-0-2-1-0-0-1-1\">DOSSIER #1295</h3>\n                </div>\n              </div>\n\n              <div data-kid=\"1-1-1-0-2-1-0-1\">\n                <div class=\"flex justify-between items-end mb-4 px-1\" data-kid=\"1-1-1-0-2-1-0-1-0\">\n                  <p class=\"text-base font-bold text-white font-heading\" data-kid=\"1-1-1-0-2-1-0-1-0-0\">BMW M3 Competition <span class=\"text-gray-500 ml-2 font-medium\" data-kid=\"1-1-1-0-2-1-0-1-0-0-0\">2023</span></p>\n                  <span class=\"text-[var(--monster-yellow)] text-xs font-black\" data-kid=\"1-1-1-0-2-1-0-1-0-1\">75%</span>\n                </div>\n                <div class=\"h-1.5 w-full bg-white/10 rounded-full overflow-hidden\" data-kid=\"1-1-1-0-2-1-0-1-1\">\n                  <div class=\"h-full bg-[var(--monster-yellow)] rounded-full w-[75%] shadow-[0_0_12px_rgba(255,216,0,0.5)]\" data-kid=\"1-1-1-0-2-1-0-1-1-0\"></div>\n                </div>\n              </div>\n\n              <div class=\"bg-white/5 p-5 rounded-[28px] border border-white/10 group cursor-pointer hover:bg-white/[0.08] transition-all flex items-center justify-between\" data-kid=\"1-1-1-0-2-1-0-2\">\n                <div class=\"flex items-center gap-4\" data-kid=\"1-1-1-0-2-1-0-2-0\">\n                  <div class=\"relative\" data-kid=\"1-1-1-0-2-1-0-2-0-0\">\n                    <img src=\"https://i.pravatar.cc/100?u=marc_tech\" class=\"w-12 h-12 rounded-xl object-cover border border-white/20 transition-transform group-hover:scale-105\" alt=\"Marc Portier\" decoding=\"async\" loading=\"lazy\" data-kid=\"1-1-1-0-2-1-0-2-0-0-0\">\n                    <div class=\"absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-green-500 border-2 border-black rounded-full\" data-kid=\"1-1-1-0-2-1-0-2-0-0-1\"></div>\n                  </div>\n                  <div data-kid=\"1-1-1-0-2-1-0-2-0-1\">\n                    <p class=\"text-sm font-bold text-white group-hover:text-[var(--monster-yellow)] transition-colors\" data-kid=\"1-1-1-0-2-1-0-2-0-1-0\">Marc Portier</p>\n                    <p class=\"text-[9px] text-gray-500 font-extrabold uppercase tracking-widest\" data-kid=\"1-1-1-0-2-1-0-2-0-1-1\">Chef d'équipe atelier</p>\n                  </div>\n                </div>\n                <div class=\"w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-gray-400 group-hover:text-white transition-all\" data-kid=\"1-1-1-0-2-1-0-2-1\">\n                  <i class=\"ti ti-chevron-right text-lg\" data-kid=\"1-1-1-0-2-1-0-2-1-0\"></i>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <div data-kid=\"1-1-1-1\">\n        <div class=\"flex items-center justify-between mb-10\" data-kid=\"1-1-1-1-0\">\n          <div class=\"flex items-center gap-5\" data-kid=\"1-1-1-1-0-0\">\n            <div class=\"w-12 h-12 bg-black rounded-xl flex items-center justify-center shadow-lg\" data-kid=\"1-1-1-1-0-0-0\">\n              <i class=\"ti ti-arrows-transfer-down text-[var(--monster-yellow)] text-xl\" data-kid=\"1-1-1-1-0-0-0-0\"></i>\n            </div>\n            <div data-kid=\"1-1-1-1-0-0-1\">\n              <h2 class=\"font-heading font-black text-2xl uppercase tracking-tight text-black\" data-kid=\"1-1-1-1-0-0-1-0\">Flux Atelier en temps réel</h2>\n              <p class=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-0.5\" data-kid=\"1-1-1-1-0-0-1-1\">Surveillance active des postes de réparation</p>\n            </div>\n          </div>\n          <div class=\"flex gap-3\" data-kid=\"1-1-1-1-0-1\">\n            <button class=\"flex items-center gap-2.5 px-6 py-3.5 bg-white border border-gray-200 rounded-xl text-[10px] font-black text-gray-600 hover:text-black hover:border-gray-300 transition-all cursor-pointer uppercase tracking-widest\" data-kid=\"1-1-1-1-0-1-0\">\n              <i class=\"ti ti-adjustments-horizontal text-base\" data-kid=\"1-1-1-1-0-1-0-0\"></i> Filtres\n            </button>\n            <button class=\"flex items-center gap-2.5 px-6 py-3.5 bg-black text-white rounded-xl text-[10px] font-black hover:bg-[var(--monster-yellow)] hover:text-black transition-all shadow-xl cursor-pointer uppercase tracking-widest\" data-kid=\"1-1-1-1-0-1-1\">\n              <i class=\"ti ti-maximize text-base\" data-kid=\"1-1-1-1-0-1-1-0\"></i> Plein Écran\n            </button>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-8\" data-kid=\"1-1-1-1-1\">\n          \n          <div class=\"space-y-6\" data-kid=\"1-1-1-1-1-0\">\n            <div class=\"flex items-center justify-between border-b-2 border-gray-100 pb-4\" data-kid=\"1-1-1-1-1-0-0\">\n              <div class=\"flex items-center gap-2.5 text-gray-400\" data-kid=\"1-1-1-1-1-0-0-0\">\n                <i class=\"ti ti-clipboard-list text-lg\" data-kid=\"1-1-1-1-1-0-0-0-0\"></i>\n                <h3 class=\"font-heading font-black text-[10px] uppercase tracking-[0.2em] text-black\" data-kid=\"1-1-1-1-1-0-0-0-1\">Prise en charge</h3>\n              </div>\n              <span class=\"bg-gray-100 text-gray-600 text-[10px] font-black px-2.5 py-1 rounded-md\" data-kid=\"1-1-1-1-1-0-0-1\">3</span>\n            </div>\n\n            <div class=\"bg-white rounded-[32px] p-7 border border-gray-100 shadow-sm hover:shadow-xl transition-all group cursor-pointer\" data-kid=\"1-1-1-1-1-0-1\">\n              <div class=\"flex justify-between items-start mb-6\" data-kid=\"1-1-1-1-1-0-1-0\">\n                <span class=\"bg-blue-50 text-blue-700 text-[9px] font-black px-2.5 py-1.5 rounded-lg uppercase tracking-wider\" data-kid=\"1-1-1-1-1-0-1-0-0\">Entretien</span>\n                <span class=\"text-[10px] text-gray-300 font-mono font-bold\" data-kid=\"1-1-1-1-1-0-1-0-1\">#DO-2024</span>\n              </div>\n              <h4 class=\"font-heading font-black text-black text-xl mb-1 group-hover:text-[var(--monster-yellow)] transition-colors\" data-kid=\"1-1-1-1-1-0-1-1\">Mercedes C63 AMG</h4>\n              <p class=\"text-sm text-gray-500 font-medium mb-8\" data-kid=\"1-1-1-1-1-0-1-2\">M. Xavier Renard • Vidange + Filtres</p>\n              <div class=\"flex items-center justify-between pt-6 border-t border-gray-50\" data-kid=\"1-1-1-1-1-0-1-3\">\n                <div class=\"flex items-center gap-2.5\" data-kid=\"1-1-1-1-1-0-1-3-0\">\n                  <div class=\"w-8 h-8 bg-gray-50 rounded-full flex items-center justify-center border border-gray-200\" data-kid=\"1-1-1-1-1-0-1-3-0-0\">\n                    <i class=\"ti ti-user text-gray-300 text-base\" data-kid=\"1-1-1-1-1-0-1-3-0-0-0\"></i>\n                  </div>\n                  <span class=\"text-[10px] text-gray-400 font-bold\" data-kid=\"1-1-1-1-1-0-1-3-0-1\">Non assigné</span>\n                </div>\n                <div class=\"flex items-center gap-1.5 text-[10px] font-black text-orange-500 bg-orange-50 px-2.5 py-1.5 rounded-lg border border-orange-100\" data-kid=\"1-1-1-1-1-0-1-3-1\">\n                  <i class=\"ti ti-clock text-sm\" data-kid=\"1-1-1-1-1-0-1-3-1-0\"></i>\n                  <span data-kid=\"1-1-1-1-1-0-1-3-1-1\">14:00</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"space-y-6\" data-kid=\"1-1-1-1-1-1\">\n            <div class=\"flex items-center justify-between border-b-2 border-[var(--monster-yellow)] pb-4\" data-kid=\"1-1-1-1-1-1-0\">\n              <div class=\"flex items-center gap-2.5 text-[var(--monster-yellow)]\" data-kid=\"1-1-1-1-1-1-0-0\">\n                <i class=\"ti ti-wrench text-lg\" data-kid=\"1-1-1-1-1-1-0-0-0\"></i>\n                <h3 class=\"font-heading font-black text-[10px] uppercase tracking-[0.2em] text-black\" data-kid=\"1-1-1-1-1-1-0-0-1\">En Mécanique</h3>\n              </div>\n              <span class=\"bg-[var(--monster-yellow)] text-black text-[10px] font-black px-2.5 py-1 rounded-md\" data-kid=\"1-1-1-1-1-1-0-1\">2</span>\n            </div>\n\n            <div class=\"bg-white rounded-[32px] p-7 shadow-xl border-l-[6px] border-l-[var(--monster-yellow)] border border-gray-100 relative group cursor-pointer hover:shadow-2xl transition-all\" data-kid=\"1-1-1-1-1-1-1\">\n              <div class=\"absolute top-6 right-6\" data-kid=\"1-1-1-1-1-1-1-0\">\n                <i class=\"ti ti-settings-automation text-[var(--monster-yellow)] animate-spin-slow text-xl\" data-kid=\"1-1-1-1-1-1-1-0-0\"></i>\n              </div>\n              <div class=\"flex justify-between items-start mb-6\" data-kid=\"1-1-1-1-1-1-1-1\">\n                <span class=\"bg-red-50 text-red-700 text-[9px] font-black px-2.5 py-1.5 rounded-lg uppercase tracking-wider\" data-kid=\"1-1-1-1-1-1-1-1-0\">Urgent</span>\n                <span class=\"text-[10px] text-gray-300 font-mono font-bold mr-8\" data-kid=\"1-1-1-1-1-1-1-1-1\">#DO-2024</span>\n              </div>\n              <h4 class=\"font-heading font-black text-black text-xl mb-1\" data-kid=\"1-1-1-1-1-1-1-2\">Ferrari F8 Tributo</h4>\n              <p class=\"text-sm text-gray-500 font-medium mb-6\" data-kid=\"1-1-1-1-1-1-1