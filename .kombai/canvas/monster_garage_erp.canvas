    <div class=\"flex items-center gap-2.5 text-green-500\" data-kid=\"1-1-1-1-1-2-0-0\">\n                <i class=\"ti ti-truck-delivery text-lg\" data-kid=\"1-1-1-1-1-2-0-0-0\"></i>\n                <h3 class=\"font-heading font-black text-[10px] uppercase tracking-[0.2em] text-black\" data-kid=\"1-1-1-1-1-2-0-0-1\">Livraison</h3>\n              </div>\n              <span class=\"bg-green-500 text-white text-[10px] font-black px-2.5 py-1 rounded-md\" data-kid=\"1-1-1-1-1-2-0-1\">1</span>\n            </div>\n\n            <div class=\"bg-white rounded-[32px] p-7 border border-green-100 shadow-sm hover:shadow-xl transition-all group cursor-pointer\" data-kid=\"1-1-1-1-1-2-1\">\n              <div class=\"flex justify-between items-start mb-6\" data-kid=\"1-1-1-1-1-2-1-0\">\n                <span class=\"bg-green-50 text-green-700 text-[9px] font-black px-2.5 py-1.5 rounded-lg uppercase tracking-wider\" data-kid=\"1-1-1-1-1-2-1-0-0\">Terminé</span>\n                <span class=\"text-[10px] text-gray-300 font-mono font-bold\" data-kid=\"1-1-1-1-1-2-1-0-1\">#DO-2024</span>\n              </div>\n              <h4 class=\"font-heading font-black text-black text-xl mb-1\" data-kid=\"1-1-1-1-1-2-1-1\">Porsche 911 GT3</h4>\n              <p class=\"text-sm text-gray-500 font-medium mb-8\" data-kid=\"1-1-1-1-1-2-1-2\">M. Antoine Durand • Géométrie</p>\n              <div class=\"flex items-center justify-between pt-6 border-t border-gray-50\" data-kid=\"1-1-1-1-1-2-1-3\">\n                 <div class=\"flex items-center gap-3\" data-kid=\"1-1-1-1-1-2-1-3-0\">\n                  <div class=\"w-8 h-8 bg-green-50 text-green-600 rounded-lg flex items-center justify-center border border-green-100\" data-kid=\"1-1-1-1-1-2-1-3-0-0\">\n                    <i class=\"ti ti-circle-check text-xl\" data-kid=\"1-1-1-1-1-2-1-3-0-0-0\"></i>\n                  </div>\n                  <span class=\"text-[10px] font-black text-green-600\" data-kid=\"1-1-1-1-1-2-1-3-0-1\">Prêt</span>\n                </div>\n                <button class=\"bg-black text-white text-[9px] font-black px-5 py-2 rounded-xl hover:bg-[var(--monster-yellow)] hover:text-black transition-all uppercase tracking-widest cursor-pointer\" data-kid=\"1-1-1-1-1-2-1-3-1\">Facturer</button>\n              </div>\n            </div>\n\n            <div class=\"border-2 border-dashed border-gray-200 rounded-[32px] p-8 flex flex-col items-center justify-center text-gray-300 group hover:border-gray-400 hover:bg-white transition-all cursor-pointer\" data-kid=\"1-1-1-1-1-2-2\">\n              <div class=\"w-12 h-12 bg-gray-50 border border-gray-100 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\" data-kid=\"1-1-1-1-1-2-2-0\">\n                <i class=\"ti ti-plus text-2xl text-gray-200 group-hover:text-gray-400\" data-kid=\"1-1-1-1-1-2-2-0-0\"></i>\n              </div>\n              <p class=\"text-[9px] font-black uppercase tracking-[0.2em] text-center opacity-40 group-hover:opacity-60\" data-kid=\"1-1-1-1-1-2-2-1\">Zone de Finition<br data-kid=\"1-1-1-1-1-2-2-1-0\">Disponible</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n</div>",
