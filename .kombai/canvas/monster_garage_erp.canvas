hite transition-all flex items-center justify-center\" data-kid=\"1-2-1-3-6-2\"><i class=\"fa-solid fa-phone text-base\" data-kid=\"1-2-1-3-6-2-0\"></i></button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"px-8 py-5 border-t border-[#2d3139] bg-[#22262d]/50 flex items-center justify-between\" data-kid=\"1-2-2\">\n      <div class=\"text-slate-500 text-xs font-medium\" data-kid=\"1-2-2-0\">\n        Affichage de <span class=\"text-white font-bold\" data-kid=\"1-2-2-0-0\">1</span> à <span class=\"text-white font-bold\" data-kid=\"1-2-2-0-1\">10</span> sur <span class=\"text-white font-bold\" data-kid=\"1-2-2-0-2\">1,284</span> clients\n      </div>\n      <div class=\"flex items-center gap-2\" data-kid=\"1-2-2-1\">\n        <button class=\"w-10 h-10 rounded-xl border border-[#2d3139] text-slate-300 hover:text-amber-400 hover:border-amber-400/30 transition-all flex items-center justify-center group\" data-kid=\"1-2-2-1-0\"><i class=\"fa-solid fa-chevron-left text-sm group-hover:-translate-x-0.5 transition-transform\" data-kid=\"1-2-2-1-0-0\"></i></button>\n        <button class=\"w-10 h-10 rounded-xl bg-amber-400 text-black font-black text-sm shadow-[0_0_15px_rgba(250,204,21,0.3)]\" data-kid=\"1-2-2-1-1\">1</button>\n        <button class=\"w-10 h-10 rounded-xl border border-[#2d3139] text-slate-400 hover:bg-white/5 hover:text-white transition-all font-bold text-sm\" data-kid=\"1-2-2-1-2\">2</button>\n        <button class=\"w-10 h-10 rounded-xl border border-[#2d3139] text-slate-400 hover:bg-white/5 hover:text-white transition-all font-bold text-sm\" data-kid=\"1-2-2-1-3\">3</button>\n        <span class=\"text-slate-600 px-2 font-black\" data-kid=\"1-2-2-1-4\">...</span>\n        <button class=\"w-10 h-10 rounded-xl border border-[#2d3139] text-slate-400 hover:bg-white/5 hover:text-white transition-all font-bold text-sm\" data-kid=\"1-2-2-1-5\">129</button>\n        <button class=\"w-10 h-10 rounded-xl border border-[#2d3139] text-slate-300 ho